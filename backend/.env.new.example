# Supabase Configuration - NEW PROJECT (Production)
# Copy this file to .env.new and fill in your new project credentials

SUPABASE_URL=https://your-new-project-id.supabase.co
SUPABASE_ANON_KEY=your-new-anon-key-here
SUPABASE_SERVICE_KEY=your-new-service-role-key-here

# Application
APP_ENV=production
LOG_LEVEL=info
